{
  "guide/introduction.md.0b79795d3efc95b9976c7c5b933afce2": "அறிமுகம்",
  "guide/introduction.md.c7382476a0ca3126a14275ddc8d1db50": "விண்மீன் பகிர்ந்தப்பட்டத் தரவுத்தளங்களுக்காக ஒரு மென்பொருள் ஆகும். மையக்கப்பட்ட வழங்கி இல்லாமல் உங்கள் அறிவியல் தரவுகளை சேர்ந்து விநியோகியுங்கள்.",
  "index.md.974724855beee3a55e93d0b47b1ee3d9": "விண்மீன்",
  "index.md.8f0a38e0c120f3eb2efb38c6fa18e5f3": "அறிவியல் தரவுகளுக்காக பகிர்ந்தப்பட்டத் தரவுத்தள அமைப்பு",
  "index.md.d6eb348ba87573860492409bf2a61d53": "உங்கள் ஆறிவியல் தரவுகளை திறந்த சமவுரிமை பிணையத்தில் சுலபமாக சேருங்கள் மற்றும் பகிருங்கள். விண்மீன் மூலமாக அறிவியல் புலத்தில் வெளிப்படைத்தன்மையையும் தரவு இறையாண்மையையும் மேம்படுத்துங்கள்.",
  "index.md.49ae48c3351f586a75dcd375e3c2aadd": "ஆவணங்களை படி",
  "index.md.7f229e35e43408bc9f6a4d85c97ee1d0": "செயலிக்கு செல்லு",
  "index.md.52f1d9be8939b29656e6f0353797a45a": "https://réseau-constellation.ca/?lg=த",
  "index.md.d1be377656960ed04f1564da21d80c8d": "நிறுவல்",
  "index.md.9de574a119337953878d4b7bdc6191ac": "https://réseau-constellation.ca/téléchargements/?lg=த",
  "index.md.818e103284097e5ac887f2b822903113": "கிட்ஹபில் பாரு",
  "index.md.9c0277c727b93d8b0fb16fe93f64c899": "https://github.com/reseau-constellation/",
  "index.md.9940780d5eb299a657be58f918e476a1": "🤝🏽",
  "index.md.72d402ca99bce5a2cf3b89685f133a9c": "தரவு பகிர்தல்",
  "index.md.cec0cd69bc234d8d16f4187e2144cbd7": "மேலும் அறிக",
  "index.md.9be681318b5facddc1b3be1ee1c350ad": "உங்களுடன் ஏற்கனவே இருக்கும் அறிவியல் தரவுத்தளங்களை விண்மீன் பிணையத்தில் பகிருங்கள். லிப்ரோஃபிஸ், எக்‌ஸெல் மற்றும் வேறு தரவுத்தளங்களிலிருந்து இறக்குமதி தானாகவே செய்யலாம்.",
  "index.md.532f5456b31a756497d719513e8510d8": "🔎",
  "index.md.23171fe4fd6ef39d7a0b5e888493cf86": "குடிமக்கள் அறிவியல்",
  "index.md.4aec692a39647e49b32f96d3f2f7e8fb": "உங்கள் திட்டத்தை ஆரம்புங்கள்",
  "index.md.506c10c754dea15d75e90c93b7395442": "மையப்படுத்தப்பட்ட வழங்கி இல்லாமல் ஒரு குடிமக்கள் அறிவியல் திட்டத்தை ஆரம்பலாம். உங்கள் தரவுகள் உங்கள் பயனாளர்களின் சாதனங்களில் தான் தாங்கும்.",
  "index.md.8645371325c77b5cbe8dfa592bf9620c": "வெளிப்படைத்தன்மையும் இறையாண்மையும்",
  "index.md.ea08e8701c63df6639d7d9b53a9bcf5a": "🪟",
  "index.md.159558ecad8b2deea55e46d9ea61a426": "விண்மீனில் தரவு தரக் கட்டுப்பாடு வசதி உள்ளது. அதே நேரத்தில் விண்மீனின் பகிர்ந்துப்பட்டக் கட்டமைப்பு இறையாண்மையையும் தரவுகளுக்கு நீண்ட கால அணுகலையும் பாதுகாக்கும்.",
  "index.md.604705e5b4135be85a4ec9875544660d": "இணையத்திலோ இணையமிலாததோ",
  "index.md.d2fe2a8d5ef9b3e1dcb2962b1f674b02": "🧑🏿‍💻",
  "index.md.aac6c53700c304e0b734f766296598b9": "இப்பொழுதுவே ஆரம்பு",
  "index.md.b36372c697a7c67f907e56e66a039e4a": "விண்மீனை உங்கள் கணினியில் நிறுவல் செய்யுங்கள், அல்லது அதை நேரடியாக இணையத் தள்ளத்தில் பயன்படுத்துக்கொங்கள்.",
  "images/distribuéDécentralisé.svg.841ec8dc6975331c9a40d1cde0136f2d": "\n    மையப்படுத்தப்பட்டது\n  ",
