  "scripts": {
    "nettoyer": "rimraf dist",
    "compiler": "pnpm versioner && pnpm nettoyer && pnpm tspc -p tsconfig.json",
    "compiler:prod": "pnpm versioner && pnpm formatter && pnpm nettoyer && pnpm tspc -p tsconfig.build.json",
    "test:node": "pnpm compiler || pnpm aegir test -t node -f \"dist/test/v2/**/*.spec.js\" --cov -- --exit",
    "test:navig": "pnpm compiler || pnpm aegir test -t browser -f \"dist/test/v2/**/*.spec.js\" --cov",
    "test:électron-principal": "pnpm compiler || pnpm aegir test -t electron-main -f \"dist/test/v2/**/*.spec.js\" --cov",
    "test:électron-rendu": "pnpm compiler || pnpm aegir test -t -f \"dist/test/v2/**/*.spec.js\" electron-renderer --cov",
    "test": "pnpm test:node && pnpm test:navig",
    "perfo": "pnpm compiler &&  benchmark 'dist/test/perfo/**/*.perfo.js'",
    "formatter": "pnpm prettier --ignore-path .gitignore --write \"**/*.+(js|ts|json)\" && pnpm eslint . --fix",
    "publier": "pnpm compiler:prod && (git commit -a -m 'version' || true) && pnpm publish",
    "versioner": "pnpm genversion  --es6 --semi src/version.ts"
  },
  "watch": {
    "build": {
      "patterns": "./src/**/*",
      "extensions": [
        ".ts",
        ".tsx"
      ]
    },
    "postbuild": "./dist/**/*"
  },
